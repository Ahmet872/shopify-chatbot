<div id="ai-chatbot">
  <div id="chat-toggle">
    <span id="chat-toggle-mark">A</span>
    <svg id="chat-toggle-close-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
    <div id="chat-badge">1</div>
  </div>
  <div id="chat-window">
    <div id="chat-header">
      <div id="chat-header-texture"></div>
      <div id="chat-header-left">
        <div id="chat-avatar">
          <span>A</span>
          <div id="chat-status-dot"></div>
        </div>
        <div id="chat-header-info">
          <div id="chat-agent-name">Mağaza Asistanı</div>
          <div id="chat-agent-status"><span class="status-dot-inline"></span>Şu an çevrimiçi</div>
        </div>
      </div>
      <button id="chat-close" onclick="toggleChat()" aria-label="Sohbeti kapat">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div id="chat-messages"></div>
    <div id="chat-input-area">
      <input type="text" id="chat-input" placeholder="Bir şey sorun..." autocomplete="off">
      <button id="chat-send" onclick="sendMessage()" aria-label="Gönder">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  #ai-chatbot{
    position:fixed;bottom:24px;right:24px;z-index:99999;
    font-family:'Helvetica Neue',Arial,sans-serif;
    --ink:#1A1A2E;
    --ink-soft:#3A3A4A;
    --paper:#FAF7F2;
    --paper-dim:#F1ECE3;
    --gold:#C9A876;
    --gold-deep:#A98A5C;
    --coral:#FF6B5C;
    --line:#E8E1D4;
  }

  /* ── TOGGLE BUTTON ─────────────────────────────────────── */
  #chat-toggle{
    width:58px;height:58px;
    background:var(--ink);
    color:var(--paper);
    border-radius:18px;
    display:flex;align-items:center;justify-content:center;
    cursor:pointer;position:relative;
    box-shadow:0 8px 24px rgba(26,26,46,0.35), 0 2px 6px rgba(26,26,46,0.2);
    transition:transform 0.25s cubic-bezier(.34,1.4,.64,1), box-shadow 0.25s ease, border-radius 0.25s ease;
    border:1px solid rgba(201,168,118,0.3);
  }
  #chat-toggle:hover{
    transform:translateY(-3px) scale(1.04);
    box-shadow:0 12px 30px rgba(26,26,46,0.4), 0 4px 10px rgba(201,168,118,0.3);
  }
  #chat-toggle-mark{
    font-family:'Times New Roman',Georgia,serif;
    font-size:23px;font-weight:600;letter-spacing:0.5px;
    line-height:1;color:var(--gold);
    transition:opacity 0.2s ease, transform 0.2s ease;
  }
  #chat-toggle-close-icon{display:none;color:var(--paper)}
  #chat-toggle.is-open{border-radius:50%}
  #chat-toggle.is-open #chat-toggle-mark{display:none}
  #chat-toggle.is-open #chat-toggle-close-icon{display:block}
  #chat-badge{
    position:absolute;top:-3px;right:-3px;
    background:var(--coral);color:white;
    width:19px;height:19px;border-radius:50%;
    font-size:10.5px;font-weight:700;
    display:flex;align-items:center;justify-content:center;
    border:2.5px solid var(--paper);
    box-shadow:0 2px 6px rgba(255,107,92,0.4);
  }

  /* ── WINDOW ─────────────────────────────────────────────── */
  #chat-window{
    width:380px;height:560px;
    background:var(--paper);
    border-radius:22px;
    box-shadow:0 24px 60px rgba(26,26,46,0.22), 0 4px 16px rgba(26,26,46,0.1);
    display:none;flex-direction:column;
    margin-bottom:16px;overflow:hidden;
    animation:riseIn 0.32s cubic-bezier(.2,.9,.3,1);
    border:1px solid var(--line);
  }
  @keyframes riseIn{
    from{opacity:0;transform:translateY(16px) scale(0.97)}
    to{opacity:1;transform:translateY(0) scale(1)}
  }

  /* ── HEADER ─────────────────────────────────────────────── */
  #chat-header{
    background:var(--ink);
    padding:20px 20px 18px;
    display:flex;justify-content:space-between;align-items:flex-start;
    position:relative;overflow:hidden;
    flex-shrink:0;
  }
  #chat-header-texture{
    position:absolute;top:-40px;right:-30px;
    width:140px;height:140px;border-radius:50%;
    background:radial-gradient(circle, rgba(201,168,118,0.18) 0%, transparent 70%);
    pointer-events:none;
  }
  #chat-header-left{display:flex;align-items:center;gap:13px;position:relative;z-index:1}
  #chat-avatar{
    width:44px;height:44px;
    background:linear-gradient(155deg, var(--gold) 0%, var(--gold-deep) 100%);
    border-radius:13px;
    display:flex;align-items:center;justify-content:center;
    position:relative;flex-shrink:0;
    box-shadow:0 3px 10px rgba(201,168,118,0.35);
  }
  #chat-avatar span{
    font-family:'Times New Roman',Georgia,serif;
    font-size:19px;font-weight:600;color:var(--ink);
  }
  #chat-status-dot{
    position:absolute;bottom:-2px;right:-2px;
    width:13px;height:13px;background:#3FBF7F;
    border-radius:50%;border:2.5px solid var(--ink);
  }
  #chat-agent-name{
    color:var(--paper);font-weight:600;font-size:15.5px;
    letter-spacing:0.1px;
  }
  #chat-agent-status{
    color:rgba(250,247,242,0.65);font-size:12px;margin-top:3px;
    display:flex;align-items:center;gap:5px;
  }
  .status-dot-inline{
    width:6px;height:6px;background:#3FBF7F;border-radius:50%;
    display:inline-block;
  }
  #chat-close{
    background:rgba(250,247,242,0.1);
    border:1px solid rgba(250,247,242,0.15);
    color:var(--paper);
    width:30px;height:30px;border-radius:50%;
    cursor:pointer;display:flex;align-items:center;justify-content:center;
    transition:background 0.2s ease;position:relative;z-index:1;
    flex-shrink:0;
  }
  #chat-close:hover{background:rgba(250,247,242,0.22)}

  /* ── MESSAGES ───────────────────────────────────────────── */
  #chat-messages{
    flex:1;overflow-y:auto;
    padding:22px 18px;
    display:flex;flex-direction:column;gap:14px;
    scroll-behavior:smooth;
    background:
      radial-gradient(circle at 90% 8%, rgba(201,168,118,0.05) 0%, transparent 45%),
      var(--paper);
  }
  #chat-messages::-webkit-scrollbar{width:4px}
  #chat-messages::-webkit-scrollbar-thumb{background:var(--line);border-radius:4px}
  #chat-messages::-webkit-scrollbar-track{background:transparent}

  .msg-row{display:flex;align-items:flex-end;gap:9px}
  .msg-row.user{flex-direction:row-reverse}
  .msg-avatar-small{
    width:26px;height:26px;
    background:var(--ink);
    border-radius:8px;
    display:flex;align-items:center;justify-content:center;
    flex-shrink:0;
  }
  .msg-avatar-small span{
    font-family:'Times New Roman',Georgia,serif;
    font-size:12px;font-weight:600;color:var(--gold);
  }
  .msg{
    max-width:84%;padding:12px 16px;
    border-radius:16px;
    line-height:1.55;font-size:14px;
    word-break:break-word;
    letter-spacing:0.1px;
  }
  .msg.user{
    background:var(--ink);
    color:var(--paper);
    border-bottom-right-radius:5px;
    box-shadow:0 3px 10px rgba(26,26,46,0.18);
  }
  .msg.bot{
    background:white;
    color:var(--ink-soft);
    border-bottom-left-radius:5px;
    box-shadow:0 2px 10px rgba(26,26,46,0.06);
    border:1px solid var(--line);
  }
  .msg.bot a{color:var(--gold-deep);text-decoration:none;border-bottom:1px solid rgba(169,138,92,0.35)}
  .msg.bot img{width:100%;border-radius:13px;margin:8px 0;display:block}

  .typing-dots{display:flex;gap:4px;padding:4px 2px}
  .typing-dots span{
    width:6px;height:6px;background:var(--gold);
    border-radius:50%;animation:bounce 1.2s infinite;
  }
  .typing-dots span:nth-child(2){animation-delay:0.2s}
  .typing-dots span:nth-child(3){animation-delay:0.4s}
  @keyframes bounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-6px)}}

  .msg-time{
    font-size:10.5px;color:#B5AFA2;margin-top:4px;
    padding:0 4px;letter-spacing:0.2px;
  }
  .msg-row.user .msg-time{text-align:right}

  .quick-replies{
    display:flex;flex-wrap:wrap;gap:8px;
    margin-top:2px;padding-left:35px;
  }
  .quick-reply-btn{
    background:white;
    border:1.3px solid var(--line);
    color:var(--ink-soft);
    padding:8px 14px;border-radius:20px;
    font-size:12.5px;font-weight:500;
    cursor:pointer;transition:all 0.18s ease;
    font-family:inherit;letter-spacing:0.1px;
  }
  .quick-reply-btn:hover{
    background:var(--ink);
    color:var(--gold);
    border-color:var(--ink);
    transform:translateY(-1px);
  }

  /* ── INPUT ──────────────────────────────────────────────── */
  #chat-input-area{
    padding:15px 16px;
    display:flex;gap:10px;
    background:white;
    border-top:1px solid var(--line);
    align-items:center;flex-shrink:0;
  }
  #chat-input{
    flex:1;padding:11px 16px;
    border:1.4px solid var(--line);
    border-radius:22px;outline:none;
    font-size:13.5px;background:var(--paper-dim);
    transition:border-color 0.2s ease, background 0.2s ease;
    font-family:inherit;color:var(--ink);
  }
  #chat-input::placeholder{color:#A8A096}
  #chat-input:focus{border-color:var(--gold);background:white}
  #chat-send{
    width:40px;height:40px;
    background:var(--ink);
    border:none;border-radius:50%;
    color:var(--gold);cursor:pointer;
    display:flex;align-items:center;justify-content:center;
    transition:transform 0.2s ease, box-shadow 0.2s ease;
    flex-shrink:0;
  }
  #chat-send:hover{
    transform:scale(1.07);
    box-shadow:0 4px 14px rgba(26,26,46,0.3);
  }

  @media (max-width:480px){
    #chat-window{
      width:calc(100vw - 24px);
      height:calc(100vh - 110px);
      max-height:600px;
    }
  }
</style>

<script>
// Session ID sekme boyunca sabit kalır — sayfa değiştirince (Kadın → Aksesuar)
// sohbet sıfırlanmaz. Sekme kapanınca sessionStorage temizlenir, yeni session başlar.
const SESSION_ID = sessionStorage.getItem('moda_chatbot_session_id') || (() => {
  const id = 'session_' + Math.random().toString(36).substr(2, 9);
  sessionStorage.setItem('moda_chatbot_session_id', id);
  return id;
})();
const BACKEND_URL = 'https://shopify-chatbot-curd.onrender.com/api/chat';
const TENANT_ID = 'moda-demo';
const CUSTOMER_NAME = {{ customer.first_name | json }} || null;

let isOpen = false;
let proactiveTimer = null;
let proactiveSent = false;
let welcomeSent = false;

function toggleChat() {
  isOpen = !isOpen;
  const win = document.getElementById('chat-window');
  const badge = document.getElementById('chat-badge');
  const toggle = document.getElementById('chat-toggle');
  if (isOpen) {
    win.style.display = 'flex';
    badge.style.display = 'none';
    toggle.classList.add('is-open');
    if (!welcomeSent) {
      welcomeSent = true;
      loadHistoryThenGreet();
    }
    setTimeout(() => document.getElementById('chat-input').focus(), 300);
  } else {
    win.style.display = 'none';
    toggle.classList.remove('is-open');
  }
}

// Sayfa değiştirip widget tekrar açıldığında önce geçmişi backend'den çeker.
// Geçmiş varsa onu ekrana basar (yeni karşılama göstermez — sohbet zaten devam ediyor).
// Geçmiş yoksa (ilk ziyaret) normal karşılama + hızlı yanıt butonlarını gösterir.
async function loadHistoryThenGreet() {
  try {
    const url = BACKEND_URL.replace('/api/chat', '') + '/api/session/' + SESSION_ID + '/history?tenant_id=' + encodeURIComponent(TENANT_ID);
    const response = await fetch(url);
    const data = await response.json();

    if (data.messages && data.messages.length > 0) {
      data.messages.forEach(m => {
        const role = m.role === 'assistant' ? 'bot' : 'user';
        addMessage(m.message, role);
      });
      return;
    }
  } catch (err) {
    // Geçmiş çekilemezse sessizce normal karşılamaya düş — kullanıcı deneyimini bozma.
  }

  showFreshGreeting();
}

function showFreshGreeting() {
  setTimeout(() => {
    const greeting = CUSTOMER_NAME
      ? 'Merhaba <strong>' + CUSTOMER_NAME + '</strong> — hoş geldiniz. Size nasıl yardımcı olabilirim?'
      : 'Merhaba, hoş geldiniz. Ne arıyordunuz?';
    addMessage(greeting, 'bot');
    setTimeout(() => {
      addQuickReplies(['Ürünleri göster', 'Siparişimi sorgula', 'Kargo bilgisi', 'İade & değişim']);
    }, 400);
  }, 300);
}

document.getElementById('chat-toggle').onclick = toggleChat;
document.getElementById('chat-input').addEventListener('keypress', e => {
  if (e.key === 'Enter') sendMessage();
});

function getTime() {
  return new Date().toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' });
}

function addMessage(text, role) {
  const msgs = document.getElementById('chat-messages');
  const row = document.createElement('div');
  row.className = 'msg-row ' + role;
  if (role === 'bot') {
    const av = document.createElement('div');
    av.className = 'msg-avatar-small';
    av.innerHTML = '<span>A</span>';
    row.appendChild(av);
  }
  const col = document.createElement('div');
  const msgEl = document.createElement('div');
  msgEl.className = 'msg ' + role;
  msgEl.innerHTML = text;
  col.appendChild(msgEl);
  const timeEl = document.createElement('div');
  timeEl.className = 'msg-time';
  timeEl.textContent = getTime();
  col.appendChild(timeEl);
  row.appendChild(col);
  msgs.appendChild(row);
  msgs.scrollTop = msgs.scrollHeight;
}

function showTyping() {
  const msgs = document.getElementById('chat-messages');
  const row = document.createElement('div');
  row.className = 'msg-row bot';
  row.id = 'typing-row';
  const av = document.createElement('div');
  av.className = 'msg-avatar-small';
  av.innerHTML = '<span>A</span>';
  row.appendChild(av);
  const msgEl = document.createElement('div');
  msgEl.className = 'msg bot';
  msgEl.innerHTML = '<div class="typing-dots"><span></span><span></span><span></span></div>';
  row.appendChild(msgEl);
  msgs.appendChild(row);
  msgs.scrollTop = msgs.scrollHeight;
}

function removeTyping() {
  const el = document.getElementById('typing-row');
  if (el) el.remove();
}

function addQuickReplies(options) {
  const msgs = document.getElementById('chat-messages');
  const container = document.createElement('div');
  container.className = 'quick-replies';
  container.id = 'quick-replies';
  options.forEach(opt => {
    const btn = document.createElement('button');
    btn.className = 'quick-reply-btn';
    btn.textContent = opt;
    btn.onclick = () => {
      document.getElementById('quick-replies')?.remove();
      document.getElementById('chat-input').value = opt;
      sendMessage();
    };
    container.appendChild(btn);
  });
  msgs.appendChild(container);
  msgs.scrollTop = msgs.scrollHeight;
}

async function sendMessage() {
  const input = document.getElementById('chat-input');
  const message = input.value.trim();
  if (!message) return;
  document.getElementById('quick-replies')?.remove();
  addMessage(message, 'user');
  input.value = '';
  showTyping();
  try {
    const response = await fetch(BACKEND_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message, sessionId: SESSION_ID, tenant_id: TENANT_ID })
    });
    const data = await response.json();
    removeTyping();
    addMessage(data.reply, 'bot');
  } catch(err) {
    removeTyping();
    addMessage('Bağlantı hatası, lütfen tekrar deneyin.', 'bot');
  }
}

// Proaktif karşılama - 60 saniye hareketsizlikte
function resetProactiveTimer() {
  if (proactiveSent) return;
  clearTimeout(proactiveTimer);
  proactiveTimer = setTimeout(function() {
    if (!isOpen && !proactiveSent) {
      proactiveSent = true;
      toggleChat();
    }
  }, 60000);
}

document.addEventListener('mousemove', resetProactiveTimer);
document.addEventListener('keypress', resetProactiveTimer);
document.addEventListener('scroll', resetProactiveTimer);
document.addEventListener('click', resetProactiveTimer);
resetProactiveTimer();
</script>
