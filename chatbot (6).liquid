<div id="ai-chatbot">
  <div id="chat-toggle">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
    <div id="chat-badge">1</div>
  </div>
  <div id="chat-window">
    <div id="chat-header">
      <div id="chat-header-left">
        <div id="chat-avatar">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="white">
            <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
          </svg>
          <div id="chat-status-dot"></div>
        </div>
        <div id="chat-header-info">
          <div id="chat-agent-name">Mağaza Asistanı</div>
          <div id="chat-agent-status">🟢 Çevrimiçi</div>
        </div>
      </div>
      <button id="chat-close" onclick="toggleChat()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div id="chat-messages"></div>
    <div id="chat-input-area">
      <input type="text" id="chat-input" placeholder="Mesajınızı yazın..." autocomplete="off">
      <button id="chat-send" onclick="sendMessage()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  #ai-chatbot{position:fixed;bottom:24px;right:24px;z-index:99999;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
  #chat-toggle{width:60px;height:60px;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 4px 20px rgba(102,126,234,0.5);transition:transform 0.2s,box-shadow 0.2s;position:relative}
  #chat-toggle:hover{transform:scale(1.08);box-shadow:0 6px 25px rgba(102,126,234,0.6)}
  #chat-badge{position:absolute;top:-4px;right:-4px;background:#ff4757;color:white;width:20px;height:20px;border-radius:50%;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;border:2px solid white}
  #chat-window{width:370px;height:540px;background:#f7f8fc;border-radius:20px;box-shadow:0 10px 40px rgba(0,0,0,0.15);display:none;flex-direction:column;margin-bottom:16px;overflow:hidden;animation:slideUp 0.3s ease}
  @keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
  #chat-header{background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);padding:16px 18px;display:flex;justify-content:space-between;align-items:center}
  #chat-header-left{display:flex;align-items:center;gap:12px}
  #chat-avatar{width:42px;height:42px;background:rgba(255,255,255,0.25);border-radius:50%;display:flex;align-items:center;justify-content:center;position:relative;border:2px solid rgba(255,255,255,0.4)}
  #chat-status-dot{position:absolute;bottom:1px;right:1px;width:11px;height:11px;background:#2ecc71;border-radius:50%;border:2px solid white}
  #chat-agent-name{color:white;font-weight:700;font-size:15px}
  #chat-agent-status{color:rgba(255,255,255,0.85);font-size:12px;margin-top:1px}
  #chat-close{background:rgba(255,255,255,0.2);border:none;color:white;width:32px;height:32px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.2s}
  #chat-close:hover{background:rgba(255,255,255,0.35)}
  #chat-messages{flex:1;overflow-y:auto;padding:20px 16px;display:flex;flex-direction:column;gap:12px;scroll-behavior:smooth}
  #chat-messages::-webkit-scrollbar{width:4px}
  #chat-messages::-webkit-scrollbar-thumb{background:#ddd;border-radius:4px}
  .msg-row{display:flex;align-items:flex-end;gap:8px}
  .msg-row.user{flex-direction:row-reverse}
  .msg-avatar-small{width:28px;height:28px;background:linear-gradient(135deg,#667eea,#764ba2);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:13px}
  .msg{max-width:85%;padding:11px 15px;border-radius:18px;line-height:1.5;font-size:14px;word-break:break-word}
  .msg.user{background:linear-gradient(135deg,#667eea,#764ba2);color:white;border-bottom-right-radius:4px}
  .msg.bot{background:white;color:#2d3436;border-bottom-left-radius:4px;box-shadow:0 2px 8px rgba(0,0,0,0.07)}
  .msg.bot a{color:#667eea;text-decoration:none}
  .msg.bot img{width:100%;border-radius:12px;margin:8px 0;display:block}
  .typing-dots{display:flex;gap:4px;padding:4px 2px}
  .typing-dots span{width:7px;height:7px;background:#b2bec3;border-radius:50%;animation:bounce 1.2s infinite}
  .typing-dots span:nth-child(2){animation-delay:0.2s}
  .typing-dots span:nth-child(3){animation-delay:0.4s}
  @keyframes bounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-6px)}}
  .msg-time{font-size:11px;color:#b2bec3;margin-top:3px;padding:0 4px}
  .msg-row.user .msg-time{text-align:right}
  .quick-replies{display:flex;flex-wrap:wrap;gap:8px;margin-top:4px;padding-left:36px}
  .quick-reply-btn{background:white;border:1.5px solid #667eea;color:#667eea;padding:7px 14px;border-radius:20px;font-size:13px;cursor:pointer;transition:all 0.2s;font-family:inherit}
  .quick-reply-btn:hover{background:#667eea;color:white}
  #chat-input-area{padding:14px 16px;display:flex;gap:10px;background:white;border-top:1px solid #eef0f5;align-items:center}
  #chat-input{flex:1;padding:10px 16px;border:1.5px solid #e8eaf0;border-radius:24px;outline:none;font-size:14px;background:#f7f8fc;transition:border-color 0.2s;font-family:inherit}
  #chat-input:focus{border-color:#667eea;background:white}
  #chat-send{width:42px;height:42px;background:linear-gradient(135deg,#667eea,#764ba2);border:none;border-radius:50%;color:white;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:transform 0.2s,box-shadow 0.2s;flex-shrink:0}
  #chat-send:hover{transform:scale(1.08);box-shadow:0 4px 12px rgba(102,126,234,0.4)}
</style>

<script>
const SESSION_ID = 'session_' + Math.random().toString(36).substr(2, 9);
const BACKEND_URL = 'https://shopify-chatbot-dr4u.onrender.com/api/chat';
const TENANT_ID = 'yitseydeneme';
const CUSTOMER_NAME = {{ customer.first_name | json }} || null;

let isOpen = false;
let proactiveTimer = null;
let proactiveSent = false;
let welcomeSent = false;

function toggleChat() {
  isOpen = !isOpen;
  const win = document.getElementById('chat-window');
  const badge = document.getElementById('chat-badge');
  if (isOpen) {
    win.style.display = 'flex';
    badge.style.display = 'none';
    // İlk açılışta karşılama mesajını göster
    if (!welcomeSent) {
      welcomeSent = true;
      setTimeout(() => {
        const greeting = CUSTOMER_NAME
          ? 'Merhaba <strong>' + CUSTOMER_NAME + '</strong>! 👋 Size nasıl yardımcı olabilirim?'
          : 'Merhaba! 👋 Ne arıyordunuz?';
        addMessage(greeting, 'bot');
        setTimeout(() => {
          addQuickReplies(['🛍️ Ürünleri göster', '📦 Siparişimi sorgula', '🚚 Kargo bilgisi', '↩️ İade & değişim']);
        }, 400);
      }, 300);
    }
    setTimeout(() => document.getElementById('chat-input').focus(), 300);
  } else {
    win.style.display = 'none';
  }
}

document.getElementById('chat-toggle').onclick = toggleChat;
document.getElementById('chat-input').addEventListener('keypress', e => {
  if (e.key === 'Enter') sendMessage();
});

function getTime() {
  return new Date().toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' });
}

function addMessage(text, role) {
  const msgs = document.getElementById('chat-messages');
  const row = document.createElement('div');
  row.className = 'msg-row ' + role;
  if (role === 'bot') {
    const av = document.createElement('div');
    av.className = 'msg-avatar-small';
    av.textContent = '🤖';
    row.appendChild(av);
  }
  const col = document.createElement('div');
  const msgEl = document.createElement('div');
  msgEl.className = 'msg ' + role;
  msgEl.innerHTML = text;
  col.appendChild(msgEl);
  const timeEl = document.createElement('div');
  timeEl.className = 'msg-time';
  timeEl.textContent = getTime();
  col.appendChild(timeEl);
  row.appendChild(col);
  msgs.appendChild(row);
  msgs.scrollTop = msgs.scrollHeight;
}

function showTyping() {
  const msgs = document.getElementById('chat-messages');
  const row = document.createElement('div');
  row.className = 'msg-row bot';
  row.id = 'typing-row';
  const av = document.createElement('div');
  av.className = 'msg-avatar-small';
  av.textContent = '🤖';
  row.appendChild(av);
  const msgEl = document.createElement('div');
  msgEl.className = 'msg bot';
  msgEl.innerHTML = '<div class="typing-dots"><span></span><span></span><span></span></div>';
  row.appendChild(msgEl);
  msgs.appendChild(row);
  msgs.scrollTop = msgs.scrollHeight;
}

function removeTyping() {
  const el = document.getElementById('typing-row');
  if (el) el.remove();
}

function addQuickReplies(options) {
  const msgs = document.getElementById('chat-messages');
  const container = document.createElement('div');
  container.className = 'quick-replies';
  container.id = 'quick-replies';
  options.forEach(opt => {
    const btn = document.createElement('button');
    btn.className = 'quick-reply-btn';
    btn.textContent = opt;
    btn.onclick = () => {
      document.getElementById('quick-replies')?.remove();
      document.getElementById('chat-input').value = opt;
      sendMessage();
    };
    container.appendChild(btn);
  });
  msgs.appendChild(container);
  msgs.scrollTop = msgs.scrollHeight;
}

async function sendMessage() {
  const input = document.getElementById('chat-input');
  const message = input.value.trim();
  if (!message) return;
  document.getElementById('quick-replies')?.remove();
  addMessage(message, 'user');
  input.value = '';
  showTyping();
  try {
    const response = await fetch(BACKEND_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message, sessionId: SESSION_ID, tenant_id: TENANT_ID })
    });
    const data = await response.json();
    removeTyping();
    addMessage(data.reply, 'bot');
  } catch(err) {
    removeTyping();
    addMessage('Bağlantı hatası, lütfen tekrar deneyin.', 'bot');
  }
}

// Proaktif karşılama - 60 saniye hareketsizlikte
function resetProactiveTimer() {
  if (proactiveSent) return;
  clearTimeout(proactiveTimer);
  proactiveTimer = setTimeout(function() {
    if (!isOpen && !proactiveSent) {
      proactiveSent = true;
      toggleChat(); // Bu zaten welcomeSent'i false'tan true'ya çevirir ve mesajı gösterir
    }
  }, 60000);
}

document.addEventListener('mousemove', resetProactiveTimer);
document.addEventListener('keypress', resetProactiveTimer);
document.addEventListener('scroll', resetProactiveTimer);
document.addEventListener('click', resetProactiveTimer);
resetProactiveTimer();
</script>
